#include "main.h"
#include <stdlib.h>

/**
 *_strdup - returns a pointer to a newly allocated space in memory, which contains a copy of the string given as a parameter.
 *@str: string pointer
 *Return: pointer to new memory
 */

char *_strdup(char *str)
{
	char *s;
	int i;

	s = malloc(strlen(str) * sizeof(char));
	if (str == NULL)
		return (NULL);
			
	for (i = 0; str[i]; i++)
		s[i] = str[i];
	s[i] = '\0';

	if (s == NULL)
		return (NULL);

	return (s);
}
